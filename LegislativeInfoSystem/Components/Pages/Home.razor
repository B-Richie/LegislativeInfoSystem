@page "/"

<PageTitle>Legislative Info System</PageTitle>

<div class="home-hero">
    <h1>Legislative Info System</h1>
    <p class="lead">Manage legislators and legislation for the State of Ohio.</p>
</div>

<div class="home-cards">
    <div class="card p-4">
        <h5>Legislators</h5>
        <p>Add and view legislators including their name and hometown.</p>
        <div class="d-flex gap-2 mt-3">
            <a class="btn btn-primary" href="/legislator-form">Add Legislator</a>
            <a class="btn btn-outline-primary" href="/legislators">View Legislators</a>
        </div>
    </div>

    <div class="card p-4">
        <h5>Legislation</h5>
        <p>Add and view legislation including title, text, and sponsors.</p>
        <div class="d-flex gap-2 mt-3">
            <a class="btn btn-primary" href="/legislation-form">Add Legislation</a>
            <a class="btn btn-outline-primary" href="/legislation">View Legislation</a>
        </div>
    </div>
</div>